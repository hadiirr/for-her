# --- Public (shown on the page) ---
NEXT_PUBLIC_HER_NAME=Emma
NEXT_PUBLIC_COUNTDOWN_LABEL=our next date
# ISO datetime, local time
NEXT_PUBLIC_COUNTDOWN_TARGET=2026-05-01T19:00:00

# --- Admin (to update status from /admin) ---
ADMIN_SECRET=pick-a-long-random-string

# --- Spotify (for now-playing) ---
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# --- Optional: persistent status storage (Vercel KV / Upstash Redis) ---
# Without these, status resets on each serverless cold start in production.
KV_REST_API_URL=
KV_REST_API_TOKEN=
